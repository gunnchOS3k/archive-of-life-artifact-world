{
  "name": "archive-of-life-artifact-world",
  "version": "2.0.0",
  "description": "Educational biodiversity exploration game with source-audited scientific data pipelines",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:data": "tsx scripts/audit-data.ts",
    "audit:coverage": "tsx scripts/audit-coverage.ts",
    "audit:archivedex": "tsx scripts/audit-archivedex.ts",
    "audit:implementation": "tsx scripts/audit-implementation-status.ts",
    "audit:release": "tsx scripts/audit-release-readiness.ts",
    "audit:species": "tsx scripts/audit-species.ts",
    "audit:time": "tsx scripts/audit-time.ts",
    "audit:biomes": "tsx scripts/audit-biomes.ts",
    "audit:earth": "tsx scripts/audit-earth.ts",
    "audit:maps": "tsx scripts/audit-temporal-maps.ts",
    "audit:maps:production": "tsx scripts/audit-temporal-maps.ts --require-verified",
    "audit:production": "tsx scripts/audit-production-readiness.ts",
    "audit:provenance": "tsx scripts/audit-provenance.ts",
    "audit:bias": "tsx scripts/audit-bias.ts",
    "report:coverage": "tsx scripts/report-coverage.ts",
    "generate:bundles": "tsx scripts/generate-bundles.ts",
    "generate:time-atlas": "tsx scripts/generate-time-atlas.ts",
    "generate:earth-grid": "tsx scripts/generate-earth-grid.ts",
    "generate:temporal-maps": "tsx scripts/generate-temporal-map-catalog.ts",
    "generate:maps": "npm run generate:earth-grid && npm run generate:temporal-maps",
    "pipeline:install": "cd data-pipeline && uv sync --all-extras",
    "pipeline:test": "cd data-pipeline && uv run pytest",
    "pipeline:lint": "cd data-pipeline && uv run ruff check .",
    "pipeline:sql": "cd data-pipeline && uv run archive-pipeline sql",
    "pipeline:build-snapshot": "cd data-pipeline && uv run archive-pipeline build-snapshot",
    "pipeline:audit": "cd data-pipeline && uv run archive-pipeline audit",
    "pipeline:all": "npm run pipeline:install && npm run pipeline:lint && npm run pipeline:test && npm run pipeline:sql && npm run pipeline:audit",
    "source:list": "tsx scripts/source-cli.ts list",
    "source:validate": "tsx scripts/source-cli.ts validate",
    "source:audit": "tsx scripts/source-cli.ts audit",
    "source:import:col": "tsx scripts/source-cli.ts import col",
    "source:import:gbif": "tsx scripts/source-cli.ts import gbif",
    "source:import:iucn": "tsx scripts/source-cli.ts import iucn",
    "source:import:pbdb": "tsx scripts/source-cli.ts import pbdb",
    "source:import:nasa": "tsx scripts/source-cli.ts import nasa",
    "source:import:neotoma": "tsx scripts/source-cli.ts import neotoma",
    "source:import:all": "tsx scripts/source-cli.ts import all",
    "status": "tsx scripts/status.ts",
    "verify": "npm run typecheck && npm run audit:maps && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1"
  }
}
