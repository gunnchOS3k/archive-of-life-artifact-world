# Optional API credentials for biodiversity and NASA Earth Systems ingestion.
# Copy to .env and fill in when running real ingestion (not required for mock/sample data).

# Catalogue of Life API
# COL_API_URL=https://api.catalogueoflife.org
# COL_API_KEY=

# GBIF API (typically no key required for read-only)
# GBIF_API_URL=https://api.gbif.org/v1

# IUCN Red List API (requires approved token)
# IUCN_API_URL=https://apiv3.iucnredlist.org/api/v3
# IUCN_API_TOKEN=

# Paleobiology Database API
# PBDB_API_URL=https://paleobiodb.org/data1.2

# NASA Earthdata Login (for authenticated downloads)
# EARTHDATA_USERNAME=
# EARTHDATA_PASSWORD=
# EARTHDATA_TOKEN=

# CMR API (public search — no key required)
# CMR_API_URL=https://cmr.earthdata.nasa.gov/search

# GIBS / Worldview WMS (public browse)
# GIBS_WMS_URL=https://gibs.earthdata.nasa.gov/wms/epsg4326/best/

# FIRMS API (free MAP_KEY from NASA)
# FIRMS_API_KEY=
# FIRMS_API_URL=https://firms.modaps.eosdis.nasa.gov/api/

# EONET API (public)
# EONET_API_URL=https://eonet.gsfc.nasa.gov/api/v3

# NASA POWER API (public)
# POWER_API_URL=https://power.larc.nasa.gov/api/

# OB.DAAC Ocean Color (Earthdata Login for downloads)
# OCEAN_COLOR_API_URL=
